{
  "name": "tinix-repo-trending",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx dev.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "worker": "tsx src/workers/crawler-worker.ts",
    "worker:hf": "tsx src/workers/hf-worker.ts",
    "worker:gh-updater": "tsx src/workers/github-updater-worker.ts",
    "worker:hf-updater": "tsx src/workers/hf-updater-worker.ts",
    "check-db": "tsx check-db.ts",
    "scheduler": "tsx src/workers/scheduler-worker.ts",
    "bootstrap": "tsx src/workers/bootstrap.ts",
    "bootstrap:hf": "tsx src/workers/bootstrap-hf.ts",
    "queue:crawler": "tsx src/workers/crawler-worker.ts",
    "queue:hf": "tsx src/workers/hf-worker.ts",
    "queue:gh-updater": "tsx src/workers/github-updater-worker.ts",
    "queue:hf-updater": "tsx src/workers/hf-updater-worker.ts",
    "start:workers": "npm-run-all --parallel queue:crawler queue:hf queue:gh-updater queue:hf-updater scheduler",
    "dev:all": "npm-run-all --parallel dev start:workers",
    "pm2:start": "npx pm2 start ecosystem.config.js",
    "pm2:stop": "npx pm2 stop ecosystem.config.js"
  },
  "dependencies": {
    "bullmq": "^5.78.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.511.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-toc": "^9.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "undici": "^8.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
